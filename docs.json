            "group": "Início",
            "pages": ["index"]
          },
          {
            "group": "Comece Aqui",
            "pages": [
              "comece-aqui/quickstart",
              "comece-aqui/autenticacao",
              "comece-aqui/ambientes"
            ]
          },
          {
            "group": "Integração",
            "pages": [
              "guias/fluxo-integracao",
              "guias/boas-praticas"
            ]
          },
          {
            "group": "Referência",
            "pages": [
              "referencia/dicionario-dados",
              "operacao/erros-comuns",
              "operacao/suporte"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Visão Geral",
            "pages": ["api-reference/introducao"]
          },
          {
            "group": "Autenticação",
            "pages": ["api-reference/autenticacao"]
          },
          {
            "group": "Cartões & Transações",
            "pages": ["api-reference/extrato-cartao"]
          },
          {
            "group": "Anexos",
            "pages": ["api-reference/download-anexo"]
          }
        ]
      },
      {
        "tab": "Collections",
        "groups": [
          {
            "group": "Collections",
            "pages": ["collections/index"]
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Changelog",
            "pages": [
              "operacao/changelog",
              "operacao/como-funciona-changelog"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Suporte",
          "href": "/operacao/suporte",
          "icon": "headset"
        }
      ]
